{
  "name": "chain-monitor",
  "version": "1.0.0",
  "description": "Real-time blockchain monitoring dashboard",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n v,api \"npm run dev:vite\" \"npm run dev:api\"",
    "dev:vite": "vite",
    "dev:api": "cd .. && python3 backend/api_server.py",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src && cd .. && pylint --rcfile=pylint.ini backend/",
    "lint:fix": "eslint src --fix",
    "lint:js": "eslint src",
    "lint:html": "html-validate index.html",
    "lint:css": "stylelint src/index.css",
    "lint:py": "cd .. && pylint --rcfile=pylint.ini backend/"
  },
  "dependencies": {
    "date-fns": "^2.30.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "concurrently": "^8.2.2",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "html-validate": "^8.7.0",
    "jsdom": "^23.0.1",
    "postcss": "^8.4.32",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vitest": "^1.1.0"
  }
}
